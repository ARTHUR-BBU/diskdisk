{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "DiskDisk",
  "version": "0.1.0",
  "identifier": "com.diskdisk.app",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [
      {
        "title": "DiskDisk - Windows 磁盘清理工具",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {
      "all": true
    },
    "fs": {
      "all": true,
      "scope": ["**"]
    }
  }
}
